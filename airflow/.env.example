AIRFLOW_UID=50000
AIRFLOW_PROJ_DIR=.

AIRFLOW_IMAGE_NAME=apache/airflow:2.10.5
AIRFLOW_WEBSERVER_PORT=8081

AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_ADMIN_FIRSTNAME=Airflow
AIRFLOW_ADMIN_LASTNAME=Admin
AIRFLOW_ADMIN_EMAIL=admin@example.com

POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow

# DAG inputs.
QUOTE_API_URL=http://host.docker.internal:8001/v1/quote/
QUOTE_API_HOST_HEADER=127.0.0.1:8001
TMDB_SCRIPT_PATH=/opt/airflow/sources/tmdb-movie-metadata/scripts/get_movie_metadata.py
NOTIFICATION_DIR=/opt/airflow/notifications

# TMDB credentials are loaded from ../tmdb-movie-metadata/.env by docker-compose.yml.
